# Mapbox access token (Directions API)
MAPBOX_ACCESS_TOKEN=

# Path to pre-baked segment scores (produced by bootstrap_scored_segments.py or prebake.py)
# Falls back to repo data/sample_network.parquet (factor defaults) if missing.
SCORED_SEGMENTS_PATH=data/scored_segments.parquet

# Comma-separated allowed CORS origins (Vercel frontend)
CORS_ORIGINS=http://localhost:3000

# Supabase — gap_reports realtime + live photo-report storage
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<your-anon-or-service-role-key>
# Public Storage bucket verified gap photos are uploaded to (created by migration 0001)
GAP_PHOTOS_BUCKET=gap-photos

# Claude vision — verifies crowdsourced gap photos before they become live pins
# Get from: https://platform.claude.com → API keys
ANTHROPIC_API_KEY=<your-anthropic-api-key>
