# Safewalk frontend environment — copy to .env.local and fill in.

# Supabase project (Dashboard → Settings → API). Powers the live gap pins + realtime.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Safewalk backend (FastAPI). Used for route scoring and the /verify-gap photo pipeline.
NEXT_PUBLIC_SAFEWALK_API_URL=http://localhost:8000

# Optional: Mapbox token for richer geocoding (falls back to OSM Nominatim if unset).
NEXT_PUBLIC_MAPBOX_TOKEN=
